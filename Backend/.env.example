# ==================== ENVIRONMENT CONFIGURATION ====================

# Application
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000

# ==================== DATABASE ====================
MONGODB_URL=mongodb+srv://username:password@cluster.mongodb.net/SmartStudy

# ==================== JWT AUTHENTICATION ====================
JWT_SECRET=your_jwt_secret_key_here_min_32_characters_long
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here_min_32_characters_long

# ==================== EMAIL CONFIGURATION ====================
MAIL_HOST=smtp.gmail.com
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password_here
MAIL_FROM_EMAIL=noreply@smartstudy.com
MAIL_FROM_NAME=Smart-Study

# ==================== CLOUDINARY ====================
CLOUDINARY_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER_NAME=Smart-Study

# ==================== RAZORPAY PAYMENT ====================
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_SECRET=your_razorpay_secret_key

# ==================== FILE UPLOAD ====================
TEMP_DIR=/tmp
MAX_FILE_SIZE=5242880

# ==================== SECURITY ====================
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

